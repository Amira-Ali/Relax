<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.Amira.Relax">

    <application
        android:allowBackup="true"
        android:fullBackupContent="true"
        android:icon="@drawable/relax"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme.NoActionBar"
        android:name="com.chaquo.python.android.PyApplication">

        <activity android:name="com.Amira.Relax.activities.TimePicker"
            android:parentActivityName="com.Amira.Relax.activities.Home"
            android:theme="@style/AppTheme"/>
        <activity android:name="com.Amira.Relax.activities.Journaling" />
        <activity android:name="com.Amira.Relax.activities.Nutrition" />
        <activity android:name="com.Amira.Relax.activities.SelfEsteem" />
        <activity android:name="com.Amira.Relax.activities.Breathing" />
        <activity android:name="com.Amira.Relax.activities.Spiritual" />
        <activity android:name="com.Amira.Relax.activities.Sport" />
        <activity android:name="com.Amira.Relax.activities.Sleeping" />
        <activity android:name="com.Amira.Relax.activities.CopingWithChange" />
        <activity android:name="com.Amira.Relax.activities.Physical" />
        <activity android:name="com.Amira.Relax.activities.Sleep" />
        <activity android:name="com.Amira.Relax.activities.Behavior" />
        <activity android:name="com.Amira.Relax.activities.Emotion" />
        <activity android:name="com.Amira.Relax.utilities.GlobalVariables" />
        <activity android:name="com.Amira.Relax.activities.NoteList" />
        <activity android:name="com.Amira.Relax.activities.Login">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.Amira.Relax.activities.AddNote"
            android:parentActivityName="com.Amira.Relax.activities.Journaling" />
        <activity
            android:name="com.Amira.Relax.activities.ChatPage"
            android:parentActivityName="com.Amira.Relax.activities.Home"
            android:theme="@style/AppTheme"/>
        <activity
            android:name="com.Amira.Relax.activities.Listview"
            android:theme="@style/AppTheme" />
        <activity
            android:name="com.Amira.Relax.activities.Results"
            android:theme="@style/AppTheme" />
        <activity
            android:name="com.Amira.Relax.activities.Home"
            android:label="@string/title_activity_home"
            android:parentActivityName="com.Amira.Relax.activities.Login"
            android:theme="@style/AppTheme"/>

        <activity
            android:name="com.Amira.Relax.activities.Feedback"
            android:parentActivityName="com.Amira.Relax.activities.Home"
            android:theme="@style/AppTheme"/>


        <receiver android:name="com.Amira.Relax.utilities.AlertReceiver" />

    </application>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <uses-permission android:name="android.permission.CALL_PHONE" />


</manifest>