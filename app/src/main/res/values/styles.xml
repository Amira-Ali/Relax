<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/light_turquoise</item>
        <item name="colorPrimaryDark">@color/dark_turquoise</item>
        <item name="colorAccent">@color/light_red</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="AppTheme">
      <item name="titleTextColor">@color/design_default_color_on_primary</item>
        <item name="actionMenuTextColor">@color/design_default_color_on_primary</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="RadioButtonStyle" >
        <item name="colorAccent">@color/light_turquoise</item>
        <item name="android:textColorSecondary">@android:color/darker_gray</item>
    </style>

    <style name="textview" >
               <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
    </style>

</resources>
